# ── JWT / Auth ──────────────────────────────────────────────
JWT_SECRET_KEY=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# ── Qdrant ─────────────────────────────────────────────────
# Qdrant Cloud: set QDRANT_URL to the full https cluster endpoint + QDRANT_API_KEY.
# Local/self-hosted: leave QDRANT_URL empty and use QDRANT_HOST/QDRANT_PORT.
QDRANT_URL=
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=
QDRANT_COLLECTION=assembly_kb
# Client timeout (seconds) for connect + read. Raise for distant Cloud regions.
QDRANT_TIMEOUT=30

# ── Embedding ──────────────────────────────────────────────
# BGE-M3: multilingual (100+ langs incl. te/hi), 1024-dim dense vectors.
# EMBEDDING_DIM MUST match both the model's output size and the dense vector
# size of the Qdrant collection — changing the model means re-seeding the corpus.
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIM=1024

# ── Indic retrieval ────────────────────────────────────────
# Normalize Indic text (NFC + zero-width cleanup) at ingest AND query time.
# Deeper script-aware normalization is used if indic-nlp-library is installed.
INDIC_NORMALIZE=true
# Multilingual cross-encoder reranking for a precision boost (esp. Indic).
# Loads a second ~2 GB model — keep off on memory-constrained instances.
RERANK_ENABLED=false
RERANK_MODEL=BAAI/bge-reranker-v2-m3
RERANK_CANDIDATES=50

# ── LLM ────────────────────────────────────────────────────
# Active provider: "openai" or "anthropic"
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
ANTHROPIC_API_KEY=sk-ant-...
LLM_MODEL=claude-sonnet-4-20250514
LLM_MAX_TOKENS=2048

# ── Tesseract OCR ─────────────────────────────────────────
TESSERACT_CMD=/usr/bin/tesseract

# ── Ingestion defaults ────────────────────────────────────
PARENT_CHUNK_SIZE=1500
CHILD_CHUNK_SIZE=300
CHUNK_OVERLAP=50
