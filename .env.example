# Ingestion / knowledge-base service — only the variables this service uses.
# It does NOT call an LLM, so no OPENAI/ANTHROPIC/JWT keys are needed here.
# Put REAL secret values in Railway Variables, never in this committed file.

# ── Qdrant ─────────────────────────────────────────────────
# Cloud: full https cluster endpoint + API key. Must match the query app's
# collection so the vectors align. (Local/self-hosted: leave QDRANT_URL empty
# and use QDRANT_HOST/QDRANT_PORT instead.)
QDRANT_URL=https://<cluster-id>.<region>.aws.cloud.qdrant.io
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=
QDRANT_COLLECTION=assembly_kb
# Connect + read timeout (seconds). Kept high for a distant Cloud region
# (e.g. Railway in Singapore reaching a sa-east-1 cluster).
QDRANT_TIMEOUT=300

# ── Embedding (MUST match the query app exactly) ───────────
# BGE-M3: multilingual (100+ langs incl. te/hi), 1024-dim dense vectors.
# Changing the model/dim means re-seeding the whole corpus.
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIM=1024
# Indic text normalization (NFC + zero-width cleanup) at ingest time.
INDIC_NORMALIZE=true

# ── Chunking (MUST match the query app) ────────────────────
PARENT_CHUNK_SIZE=1500
CHILD_CHUNK_SIZE=300
CHUNK_OVERLAP=50

# ── Tesseract OCR ──────────────────────────────────────────
TESSERACT_CMD=/usr/bin/tesseract
